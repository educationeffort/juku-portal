rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isTeacher() {
      return request.auth != null &&
        request.auth.uid in get(/databases/$(database)/documents/config/teacher).data.teacherUids;
    }

    function isStudent(studentId) {
      return request.auth != null &&
        exists(/databases/$(database)/documents/students/$(studentId)) &&
        get(/databases/$(database)/documents/students/$(studentId)).data.uid == request.auth.uid;
    }

    match /config/{doc} {
      allow read: if request.auth != null;
      allow write: if isTeacher();
    }

    match /students/{studentId} {
      allow read:  if isTeacher() || isStudent(studentId);
      allow write: if isTeacher();
    }

    match /materials/{materialId} {
      allow read:  if isTeacher() ||
                     (request.auth != null &&
                      resource.data.targets.hasAny([
                        get(/databases/$(database)/documents/students/$(request.auth.uid)).data.studentId
                      ]));
      allow write: if isTeacher();
    }

    match /submissions/{submissionId} {
      allow read:  if isTeacher() ||
                     (request.auth != null && resource.data.studentId ==
                      get(/databases/$(database)/documents/students/$(request.auth.uid)).data.studentId);
      allow create: if request.auth != null &&
                      request.resource.data.studentId ==
                      get(/databases/$(database)/documents/students/$(request.auth.uid)).data.studentId;
      allow update: if isTeacher();
      allow delete: if isTeacher();
    }
  }
}
